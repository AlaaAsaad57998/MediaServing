{
  "name": "media-serving",
  "version": "1.0.0",
  "description": "Cloudinary-like media processing service using Fastify, Sharp, and S3-compatible storage",
  "main": "src/index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/index.js",
    "dev": "cross-env NODE_ENV=development node --watch src/index.js",
    "migrate": "node src/scripts/migrate-cloudinary.js",
    "migrate:dry": "node src/scripts/migrate-cloudinary.js --dry-run",
    "migrate:full": "node src/scripts/migrate-cloudinary.js --limit 0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/lib-storage": "^3.800.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.1.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "ioredis": "^5.6.1",
    "mime-types": "^3.0.1",
    "sharp": "^0.34.1"
  }
}
